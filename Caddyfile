{$MUNKI_DOMAIN} {
    tls {$ACME_EMAIL} {
        client_auth {
            mode require_and_verify
            trust_pool file {
                pem_file /etc/caddy/ca.crt
            }
        }
    }

    root * /srv/munki/repo
    file_server
}

{$MANAGE_DOMAIN} {
    tls {$ACME_EMAIL} {
        alpn http/1.1
    }

    basic_auth {
        {$WEBDAV_USER} {$WEBDAV_PASS_HASH}
    }

    reverse_proxy webdav:80
}
